# QA Analytics Platform — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

PORT=4000
DASHBOARD_URL=http://localhost:4000

# Slack Incoming Webhook URL (optional — alerts disabled if not set)
SLACK_WEBHOOK=

# Release gate thresholds (defaults shown)
GATE_PASS_RATE_MIN=0.95
GATE_MAX_NEW_FAILURES=0
GATE_MAX_FLAKY_RATE=0.03
