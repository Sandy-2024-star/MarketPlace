# Environment configuration for Flow Marketplace automation framework.
# Copy this file to .env and fill in real values. Never commit .env.

BASE_URL=https://marketplace.flow.staging.linktoany.com
API_URL=https://marketplace.flow.staging.linktoany.com/api/1.0

USERNAME=
PASSWORD=

# Set to true to suppress browser automation fingerprints (stealth mode)
STEALTH_MODE=false

# Shopify — used for Square→Shopify E2E target connection
SHOPIFY_URL=https://accounts.shopify.com/login
SHOPIFY_USERNAME=
SHOPIFY_PASSWORD=
SHOPIFY_STORES_URL=
SHOPIFY_ORG_ID=
SHOPIFY_SHOP=
SHOPIFY_SSO_URL=
SHOPIFY_FLOW_URL=
# CI: base64-encoded session JSON (set as CI secret, takes priority over session file on disk)
SHOPIFY_SESSION_B64=

# Square source credentials for wizard Step 2
SQUARE_USERNAME=
SQUARE_PASSWORD=
SQUARE_ACCOUNT_ID=

# Set HEADED=true to run browser in headed mode
HEADED=true
